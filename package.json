{
  "name": "vscode-4d-callchain-monorepo",
  "private": true,
  "version": "0.1.16",
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/ide-server",
    "packages/vscode-client"
  ],
  "scripts": {
    "build": "npm run build -w @4d/core && npm run build -w @4d/language-server && npm run build -w @4d/ide-server && npm run compile -w vscode-4d-callchain",
    "watch": "npm run watch -w vscode-4d-callchain",
    "build-builtins": "node ./scripts/build-builtins.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
