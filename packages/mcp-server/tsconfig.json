{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "noImplicitAny": true,
    "noImplicitReturns": true
  },
  "include": ["src/**/*.ts"]
}
