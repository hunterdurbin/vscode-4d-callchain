{
  "name": "vscode-4d-callchain",
  "displayName": "4D Call Chain Explorer",
  "description": "Explore call chains in 4D v21 projects: methods, class functions, plugins. Tree + graph views, test integration.",
  "version": "0.2.0",
  "publisher": "hunterdurbin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:4d",
    "workspaceContains:**/Project/Sources/catalog.4DCatalog",
    "workspaceContains:**/Project/**/*.4dm"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "callchain",
          "title": "4D Call Chain",
          "icon": "resources/icons/callchain.svg"
        }
      ]
    },
    "views": {
      "callchain": [
        {
          "id": "callchain.callers",
          "name": "Callers (up)"
        },
        {
          "id": "callchain.callees",
          "name": "Callees (down)"
        },
        {
          "id": "callchain.search",
          "name": "Symbols"
        }
      ]
    },
    "commands": [
      {
        "command": "callchain.reindex",
        "title": "4D Call Chain: Reindex Project"
      },
      {
        "command": "callchain.setupMcp",
        "title": "4D Call Chain: Set up MCP server for AI agents"
      },
      {
        "command": "callchain.showGraph",
        "title": "4D Call Chain: Show Graph"
      },
      {
        "command": "callchain.revealAtCursor",
        "title": "4D Call Chain: Reveal at Cursor"
      },
      {
        "command": "callchain.pickSymbol",
        "title": "4D Call Chain: Pick Symbol…"
      },
      {
        "command": "callchain.runTestsForClass",
        "title": "4D Call Chain: Run Tests for Class"
      },
      {
        "command": "callchain.runAllTests",
        "title": "4D Call Chain: Run All Tests"
      },
      {
        "command": "callchain.jumpToTests",
        "title": "4D Call Chain: Show Tests Covering This"
      },
      {
        "command": "callchain.showTestCallers",
        "title": "4D Call Chain: Show Test Callers"
      },
      {
        "command": "callchain.openSymbol",
        "title": "4D Call Chain: Open Symbol"
      },
      {
        "command": "callchain.lockCallers",
        "title": "Lock Callers",
        "icon": "$(unlock)"
      },
      {
        "command": "callchain.unlockCallers",
        "title": "Unlock Callers",
        "icon": "$(lock)"
      },
      {
        "command": "callchain.lockCallees",
        "title": "Lock Callees",
        "icon": "$(unlock)"
      },
      {
        "command": "callchain.unlockCallees",
        "title": "Unlock Callees",
        "icon": "$(lock)"
      },
      {
        "command": "callchain.contextShowCallers",
        "title": "Show callers"
      },
      {
        "command": "callchain.contextShowCallees",
        "title": "Show callees"
      },
      {
        "command": "callchain.contextShowGraph",
        "title": "Show graph from here"
      },
      {
        "command": "callchain.contextPinCallers",
        "title": "Pin & lock in Callers"
      },
      {
        "command": "callchain.contextPinCallees",
        "title": "Pin & lock in Callees"
      },
      {
        "command": "callchain.contextCopyName",
        "title": "Copy name"
      },
      {
        "command": "callchain.contextCopyFileLine",
        "title": "Copy file:line"
      },
      {
        "command": "callchain.collapseSubtree",
        "title": "Collapse sub-folders"
      },
      {
        "command": "callchain.contextGroupByTheme",
        "title": "Group by theme / Group by name (toggle)"
      },
      {
        "command": "callchain.resetSymbols",
        "title": "Reset filters & sorting",
        "icon": "$(discard)"
      },
      {
        "command": "callchain.filterCallers",
        "title": "Filter Callers…",
        "icon": "$(filter)"
      },
      {
        "command": "callchain.filterCallersAccess",
        "title": "Filter Callers by Read/Write…",
        "icon": "$(arrow-both)"
      },
      {
        "command": "callchain.filterCallersTests",
        "title": "Filter Callers by Tests…",
        "icon": "$(beaker)"
      },
      {
        "command": "callchain.filterCallees",
        "title": "Filter Callees…",
        "icon": "$(filter)"
      },
      {
        "command": "callchain.filterSymbols",
        "title": "Filter Symbols…",
        "icon": "$(filter)"
      },
      {
        "command": "callchain.clearFilterCallers",
        "title": "Clear all filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "callchain.clearFilterCallees",
        "title": "Clear filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "callchain.clearFilterSymbols",
        "title": "Clear filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "callchain.toggleSymbolsSort",
        "title": "Toggle sort (Name → Callers↓ → Callers↑)",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "callchain.toggleCallerFilter",
        "title": "Toggle caller filter (off → ≥1 → 0)",
        "icon": "$(call-incoming)"
      },
      {
        "command": "callchain.toggleFlattenSymbols",
        "title": "Toggle prefix folders (flat / grouped)",
        "icon": "$(list-flat)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "callchain.runTestsForClass",
          "when": "config.callchain.tests.enabled"
        },
        {
          "command": "callchain.runAllTests",
          "when": "config.callchain.tests.enabled"
        },
        {
          "command": "callchain.jumpToTests",
          "when": "false"
        },
        {
          "command": "callchain.showTestCallers",
          "when": "false"
        },
        {
          "command": "callchain.openSymbol",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "callchain.revealAtCursor",
          "when": "resourceExtname == .4dm",
          "group": "navigation"
        },
        {
          "command": "callchain.showGraph",
          "when": "resourceExtname == .4dm",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "callchain.lockCallers",
          "when": "view == callchain.callers && !callchain.callersLocked",
          "group": "navigation"
        },
        {
          "command": "callchain.unlockCallers",
          "when": "view == callchain.callers && callchain.callersLocked",
          "group": "navigation"
        },
        {
          "command": "callchain.lockCallees",
          "when": "view == callchain.callees && !callchain.calleesLocked",
          "group": "navigation"
        },
        {
          "command": "callchain.unlockCallees",
          "when": "view == callchain.callees && callchain.calleesLocked",
          "group": "navigation"
        },
        {
          "command": "callchain.filterCallers",
          "when": "view == callchain.callers",
          "group": "navigation@0"
        },
        {
          "command": "callchain.filterCallersTests",
          "when": "view == callchain.callers",
          "group": "navigation@1"
        },
        {
          "command": "callchain.filterCallersAccess",
          "when": "view == callchain.callers && callchain.callersFieldLike",
          "group": "navigation@2"
        },
        {
          "command": "callchain.clearFilterCallers",
          "when": "view == callchain.callers && (callchain.callersFiltered || callchain.callersAccessFiltered || callchain.callersTestFiltered)",
          "group": "navigation@3"
        },
        {
          "command": "callchain.filterCallees",
          "when": "view == callchain.callees",
          "group": "navigation@0"
        },
        {
          "command": "callchain.clearFilterCallees",
          "when": "view == callchain.callees && callchain.calleesFiltered",
          "group": "navigation@1"
        },
        {
          "command": "callchain.filterSymbols",
          "when": "view == callchain.search",
          "group": "navigation@0"
        },
        {
          "command": "callchain.clearFilterSymbols",
          "when": "view == callchain.search && callchain.symbolsFiltered",
          "group": "navigation@1"
        },
        {
          "command": "callchain.toggleSymbolsSort",
          "when": "view == callchain.search",
          "group": "navigation@1"
        },
        {
          "command": "callchain.toggleCallerFilter",
          "when": "view == callchain.search",
          "group": "navigation@2"
        },
        {
          "command": "callchain.toggleFlattenSymbols",
          "when": "view == callchain.search",
          "group": "navigation@3"
        },
        {
          "command": "callchain.resetSymbols",
          "when": "view == callchain.search",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "callchain.contextShowCallers",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "navigation@1"
        },
        {
          "command": "callchain.contextShowCallees",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "navigation@2"
        },
        {
          "command": "callchain.contextShowGraph",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "navigation@3"
        },
        {
          "command": "callchain.contextPinCallers",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "pin@1"
        },
        {
          "command": "callchain.contextPinCallees",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "pin@2"
        },
        {
          "command": "callchain.contextCopyName",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "copy@1"
        },
        {
          "command": "callchain.contextCopyFileLine",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.symbol/",
          "group": "copy@2"
        },
        {
          "command": "callchain.collapseSubtree",
          "when": "view =~ /^callchain\\./ && viewItem =~ /^callchain\\.(symbol|folder)/",
          "group": "collapse@1"
        },
        {
          "command": "callchain.contextGroupByTheme",
          "when": "view == callchain.search && (viewItem == callchain.folder.group.Constant || viewItem == callchain.folder.group.BuiltinConstant)",
          "group": "view@1"
        }
      ]
    },
    "configuration": [
      {
        "title": "Indexing",
        "properties": {
          "callchain.index.projectRoot": {
            "type": "string",
            "default": "",
            "description": "Absolute path to 4D project root (folder containing 'Project/'). Defaults to first workspace folder.",
            "scope": "resource"
          },
          "callchain.index.exclusions": {
            "type": "array",
            "default": [
              "DerivedData",
              "Libraries",
              ".git",
              "node_modules"
            ],
            "description": "Folder names (anywhere in the tree) to skip during indexing.",
            "scope": "resource"
          },
          "callchain.index.builtinConstantsPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Optional absolute paths to a 4D 4D_ConstantsEN.xlf file. If empty, the extension auto-detects tool4d.app / 4D installations under /Applications.",
            "scope": "resource"
          },
          "callchain.index.autoOnStartup": {
            "type": "boolean",
            "default": true,
            "description": "Build (or load) the index automatically on activation.",
            "scope": "window"
          }
        }
      },
      {
        "title": "Language Server",
        "properties": {
          "callchain.server.enabled": {
            "type": "boolean",
            "default": false,
            "description": "Run the 4D language server (go-to-definition, find references, workspace symbols, document outline, native call hierarchy, semantic tokens, diagnostics/linter, hover, completion, signature help). Off by default in the lean Call-Chain-only build; it runs in a separate process that re-indexes the whole project. Note: the packaged .vsix does not bundle this server, so enabling it there has no effect — run the extension from source to use it.",
            "scope": "window"
          }
        }
      },
      {
        "title": "Code Lenses",
        "properties": {
          "callchain.codeLens.showCallers": {
            "type": "boolean",
            "default": true,
            "description": "Show the '▲ N callers' code lens above functions and methods.",
            "scope": "window"
          },
          "callchain.codeLens.showCallees": {
            "type": "boolean",
            "default": false,
            "description": "Show the '▼ N callees' code lens above functions and methods.",
            "scope": "window"
          },
          "callchain.codeLens.showViaBase": {
            "type": "boolean",
            "default": true,
            "description": "Show the '⊕ N via base' code lens above an overriding class function — the call sites that resolve to an ancestor's method but can dispatch to this override at runtime. Surfaces polymorphic-dispatch callers that '▲ N callers' (direct edges only) misses, so overrides aren't mistaken for dead code.",
            "scope": "window"
          },
          "callchain.codeLens.showGraph": {
            "type": "boolean",
            "default": false,
            "description": "Show the '◎ Graph' code lens above functions/methods and the '◎ Graph class' lens on class declarations.",
            "scope": "window"
          },
          "callchain.codeLens.showOverrides": {
            "type": "boolean",
            "default": true,
            "description": "Show the '↧ N overrides' code lens above class functions that are overridden by subclasses (classes that extend this one).",
            "scope": "window"
          },
          "callchain.codeLens.showOverriding": {
            "type": "boolean",
            "default": true,
            "description": "Show the '↥ overrides {Class}' code lens above a class function that overrides a function inherited from an ancestor class.",
            "scope": "window"
          },
          "callchain.codeLens.showExtendedBy": {
            "type": "boolean",
            "default": true,
            "description": "Show the '↥ Extended by N' code lens on a class declaration, counting subclasses (direct, plus total descendants when deeper).",
            "scope": "window"
          },
          "callchain.codeLens.showPropertyUsage": {
            "type": "boolean",
            "default": true,
            "description": "Show the '↔ N reads · M writes' usage code lens above class properties, computed-attribute getters/setters, and ORDA aliases (replaces the '▲ N callers' lens for these field-like members). When multiple share one line, each lens is prefixed with the member name.",
            "scope": "window"
          }
        }
      },
      {
        "title": "Views & Graph",
        "properties": {
          "callchain.views.showCallSiteSnippets": {
            "type": "boolean",
            "default": true,
            "description": "When a caller/callee has multiple call sites in the same file, show the source-line snippet next to the line number. Disable to show 'line N' only.",
            "scope": "window"
          },
          "callchain.graph.maxDepth": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "maximum": 8,
            "description": "Default maximum BFS depth when rendering the graph.",
            "scope": "window"
          }
        }
      },
      {
        "title": "Coverage",
        "properties": {
          "callchain.coverage.showHints": {
            "type": "boolean",
            "default": false,
            "description": "Show gutter markers on functions not reached by any test function. Works on its own — does not require callchain.tests.enabled.",
            "scope": "window"
          },
          "callchain.coverage.testFunctionPattern": {
            "type": "string",
            "default": "^test_",
            "description": "Regular expression matched against a function's name to decide whether it is a test (a coverage seed). Functions that match are excluded from the uncovered list. Defaults to the test_ prefix convention.",
            "scope": "resource"
          },
          "callchain.coverage.testClassPattern": {
            "type": "string",
            "default": "_Test$",
            "description": "Regular expression matched against a class name to decide whether it is a test class. Functions belonging to a matching class are excluded from the uncovered list. Defaults to the _Test suffix convention.",
            "scope": "resource"
          },
          "callchain.coverage.testMethodPattern": {
            "type": "string",
            "default": "^UT_",
            "description": "Regular expression matched against a project method's name to decide whether it is a test (a coverage seed). Project methods that match are treated as tests and excluded from the uncovered list, even when they don't belong to a test class. Defaults to the UT_ prefix convention.",
            "scope": "resource"
          }
        }
      },
      {
        "title": "Testing",
        "properties": {
          "callchain.tests.enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable test integration: the test runner commands, ScottHarris.4d-testing-extension delegation, gutter pass/fail decorations, and the per-index coverage computation that powers the 'N tests cover this' code lens. Off by default; not part of the Call Chain core.",
            "scope": "resource"
          },
          "callchain.tests.command": {
            "type": "string",
            "default": "make test class={class} format=json outputPath={jsonOutputPath}",
            "description": "Command template used when running tests via our fallback runner (ScottHarris.4d-testing-extension is preferred when installed). {class} is the test class name; {jsonOutputPath} is the value of callchain.jsonResultsPath.",
            "scope": "resource"
          },
          "callchain.tests.jsonResultsPath": {
            "type": "string",
            "default": "Components/testing.4dbase/test-results/results.json",
            "description": "Relative path (from projectRoot) where the JSON test-results file is written and read. Matches the format consumed by ScottHarris.4d-testing-extension.",
            "scope": "resource"
          }
        }
      },
      {
        "title": "Lint",
        "properties": {
          "callchain.lint.rules": {
            "type": "object",
            "default": {},
            "description": "Best-practices lint rules. Each entry maps a rule id to a severity ('off' | 'info' | 'warning' | 'error') OR an object { severity, options } for per-rule tuning. All rules ship off-by-default; opt in here. Known rule ids: 'style/trailing-whitespace', 'types/missing-param-type', 'types/missing-return-type', 'decl/implicit-local', 'unused/method-no-callers', 'unused/parameter', 'unused/local', 'style/class-pascal-case', 'style/method-camel-case', 'style/missing-docstring-on-public', 'style/builtin-name-collision'.",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": [
                    "off",
                    "info",
                    "warning",
                    "error"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "severity": {
                      "type": "string",
                      "enum": [
                        "off",
                        "info",
                        "warning",
                        "error"
                      ]
                    },
                    "options": {
                      "type": "object"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "scope": "resource"
          }
        }
      },
      {
        "title": "MCP",
        "properties": {
          "callchain.mcp.binPath": {
            "type": "string",
            "default": "",
            "description": "Absolute path to the 4D Call Chain MCP server bin.js, used by the 'Set up MCP server for AI agents' command. Leave empty to auto-resolve. Set this when running from a packaged .vsix, where the server isn't bundled.",
            "scope": "machine"
          }
        }
      }
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunterdurbin/vscode-4d-callchain.git",
    "directory": "packages/vscode-client"
  },
  "bugs": {
    "url": "https://github.com/hunterdurbin/vscode-4d-callchain/issues"
  },
  "homepage": "https://github.com/hunterdurbin/vscode-4d-callchain#readme",
  "scripts": {
    "vscode:prepublish": "node esbuild.js",
    "esbuild": "node esbuild.js",
    "compile": "tsc -p ./",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "package:full": "node scripts/package-full.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@4d/core": "*",
    "@4d/language-server": "*",
    "@4d/mcp-server": "*",
    "cytoscape": "^3.33.3",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "vscode-languageclient": "^9.0.1"
  }
}
