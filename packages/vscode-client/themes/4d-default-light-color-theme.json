{
  "$schema": "vscode://schemas/color-theme",
  "name": "4D Default Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#FAFAFA",
    "editor.foreground": "#383A42",
    "editorCursor.foreground": "#526FFF",
    "editor.lineHighlightBackground": "#F0F0F1",
    "editor.selectionBackground": "#E5E5E6",
    "editor.findMatchHighlightBackground": "#BFCEFF",
    "editorIndentGuide.background": "#E5E5E6",
    "editorIndentGuide.activeBackground": "#A0A1A7",
    "editorLineNumber.foreground": "#9D9D9F",
    "editorLineNumber.activeForeground": "#383A42",
    "editorWhitespace.foreground": "#E5E5E6",
    "editorRuler.foreground": "#E5E5E6",
    "editorBracketHighlight.foreground1": "#C18401",
    "editorBracketHighlight.foreground2": "#A626A4",
    "editorBracketHighlight.foreground3": "#0184BC",
    "editorBracketHighlight.foreground4": "#50A14F",
    "editorBracketHighlight.foreground5": "#4078F2",
    "editorBracketHighlight.foreground6": "#986801",
    "editorBracketHighlight.unexpectedBracket.foreground": "#E45649",
    "editorBracketPairGuide.activeBackground1": "#C18401",
    "editorBracketPairGuide.activeBackground2": "#A626A4",
    "editorBracketPairGuide.activeBackground3": "#0184BC",
    "editorBracketPairGuide.activeBackground4": "#50A14F",
    "editorBracketPairGuide.activeBackground5": "#4078F2",
    "editorBracketPairGuide.activeBackground6": "#986801"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#A0A1A7", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#50A14F" }
    },
    {
      "scope": "constant.character.escape",
      "settings": { "foreground": "#0184BC" }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.decimal", "constant.numeric.hexadecimal"],
      "settings": { "foreground": "#986801" }
    },
    {
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#986801" }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#A626A4" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison"],
      "settings": { "foreground": "#0184BC" }
    },
    {
      "scope": "storage.type",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "storage.modifier",
      "settings": { "foreground": "#A626A4" }
    },
    {
      "scope": "entity.name.function",
      "settings": { "foreground": "#4078F2" }
    },
    {
      "scope": "entity.name.function.member",
      "settings": { "foreground": "#4078F2" }
    },
    {
      "scope": "entity.name.class",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "entity.name.type",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "support.function",
      "settings": { "foreground": "#4078F2" }
    },
    {
      "scope": "support.type",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "support.class",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "support.variable",
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "support.constant",
      "settings": { "foreground": "#986801" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "variable.parameter",
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "variable.other.member",
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "variable.language",
      "settings": { "foreground": "#A626A4", "fontStyle": "italic" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": "punctuation",
      "settings": { "foreground": "#383A42" }
    },
    {
      "scope": [
        "punctuation.section.arguments.begin.bracket.round.4d",
        "punctuation.section.arguments.end.bracket.round.4d",
        "punctuation.section.scope.begin.bracket.curly.4d",
        "punctuation.section.scope.end.bracket.curly.4d",
        "punctuation.terminator.statement.4d",
        "punctuation.separator.delimiter.4d",
        "punctuation.separator.dot-access.4d",
        "punctuation.separator.pointer-access.4d",
        "punctuation.definition.begin.bracket.square.4d",
        "punctuation.definition.end.bracket.square.4d"
      ],
      "settings": { "foreground": "#0184BC" }
    },
    {
      "scope": [
        "variable.local.name.4d",
        "variable.interprocess.name.4d",
        "variable.parameter.4d",
        "variable.other.member.4d",
        "variable.name.4d"
      ],
      "settings": { "foreground": "#E45649" }
    },
    {
      "scope": [
        "variable.language.this.4d",
        "variable.language.super.4d",
        "variable.language.4d"
      ],
      "settings": { "foreground": "#A626A4", "fontStyle": "italic" }
    },
    {
      "scope": "support.table.name.4d",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": "storage.type.4d",
      "settings": { "foreground": "#C18401" }
    },
    {
      "scope": ["constant.language.4d", "constant.numeric.decimal.4d", "constant.numeric.hexadecimal.4d"],
      "settings": { "foreground": "#986801" }
    },
    {
      "scope": ["comment.line.double-slash.4d", "comment.block.4d"],
      "settings": { "foreground": "#A0A1A7", "fontStyle": "italic" }
    },
    {
      "scope": "string.quoted.double.4d",
      "settings": { "foreground": "#50A14F" }
    },
    {
      "scope": "entity.name.function.4d",
      "settings": { "foreground": "#4078F2" }
    }
  ],
  "semanticTokenColors": {
    "operator:4d":              { "foreground": "#0184BC" },
    "keyword:4d":               { "foreground": "#A626A4" },
    "string:4d":                { "foreground": "#50A14F" },
    "number:4d":                { "foreground": "#986801" },
    "comment:4d":               { "foreground": "#A0A1A7", "fontStyle": "italic" },
    "type:4d":                  { "foreground": "#C18401" },
    "constant:4d":              { "foreground": "#986801" },
    "parameter:4d":             { "foreground": "#E45649" },
    "variable.local:4d":        { "foreground": "#E45649" },
    "variable.process:4d":      { "foreground": "#E45649" },
    "variable.interprocess:4d": { "foreground": "#E45649" },
    "method:4d":                { "foreground": "#4078F2" },
    "method.defaultLibrary:4d": { "foreground": "#A626A4", "fontStyle": "italic" },
    "method.plugin:4d":         { "foreground": "#A626A4" },
    "method.static:4d":         { "foreground": "#4078F2" },
    "function:4d":              { "foreground": "#4078F2" },
    "property:4d":              { "foreground": "#E45649" },
    "table:4d":                 { "foreground": "#C18401" },
    "field:4d":                 { "foreground": "#E45649" }
  }
}
