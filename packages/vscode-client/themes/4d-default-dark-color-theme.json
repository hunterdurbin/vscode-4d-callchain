{
  "$schema": "vscode://schemas/color-theme",
  "name": "4D Default Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#282C34",
    "editor.foreground": "#ABB2BF",
    "editorCursor.foreground": "#528BFF",
    "editor.lineHighlightBackground": "#2C313C",
    "editor.selectionBackground": "#3E4451",
    "editor.findMatchHighlightBackground": "#42557B",
    "editorIndentGuide.background": "#3B4048",
    "editorIndentGuide.activeBackground": "#5C6370",
    "editorLineNumber.foreground": "#5C6370",
    "editorLineNumber.activeForeground": "#ABB2BF",
    "editorWhitespace.foreground": "#3B4048",
    "editorRuler.foreground": "#3B4048",
    "editorBracketHighlight.foreground1": "#E5C07B",
    "editorBracketHighlight.foreground2": "#C678DD",
    "editorBracketHighlight.foreground3": "#56B6C2",
    "editorBracketHighlight.foreground4": "#98C379",
    "editorBracketHighlight.foreground5": "#61AFEF",
    "editorBracketHighlight.foreground6": "#D19A66",
    "editorBracketHighlight.unexpectedBracket.foreground": "#E06C75",
    "editorBracketPairGuide.activeBackground1": "#E5C07B",
    "editorBracketPairGuide.activeBackground2": "#C678DD",
    "editorBracketPairGuide.activeBackground3": "#56B6C2",
    "editorBracketPairGuide.activeBackground4": "#98C379",
    "editorBracketPairGuide.activeBackground5": "#61AFEF",
    "editorBracketPairGuide.activeBackground6": "#D19A66"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5C6370", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#98C379" }
    },
    {
      "scope": "constant.character.escape",
      "settings": { "foreground": "#56B6C2" }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.decimal", "constant.numeric.hexadecimal"],
      "settings": { "foreground": "#D19A66" }
    },
    {
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#ABB2BF", "fontStyle": "underline" }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#C678DD" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison"],
      "settings": { "foreground": "#ABB2BF" }
    },
    {
      "scope": "storage.type",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "storage.modifier",
      "settings": { "foreground": "#C678DD" }
    },
    {
      "scope": "entity.name.function",
      "settings": { "foreground": "#61AFEF" }
    },
    {
      "scope": "entity.name.function.member",
      "settings": { "foreground": "#61AFEF" }
    },
    {
      "scope": "entity.name.class",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "entity.name.type",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "support.function",
      "settings": { "foreground": "#61AFEF" }
    },
    {
      "scope": "support.type",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "support.class",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "support.variable",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "support.constant",
      "settings": { "foreground": "#D19A66" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "variable.parameter",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "variable.other.member",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "variable.language",
      "settings": { "foreground": "#C678DD", "fontStyle": "italic" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": "punctuation",
      "settings": { "foreground": "#ABB2BF" }
    },
    {
      "scope": [
        "punctuation.terminator.statement.4d",
        "punctuation.separator.delimiter.4d",
        "punctuation.separator.dot-access.4d",
        "punctuation.separator.pointer-access.4d"
      ],
      "settings": { "foreground": "#ABB2BF" }
    },
    {
      "scope": [
        "variable.local.name.4d",
        "variable.interprocess.name.4d",
        "variable.parameter.4d",
        "variable.other.member.4d",
        "variable.name.4d"
      ],
      "settings": { "foreground": "#E06C75" }
    },
    {
      "scope": [
        "variable.language.this.4d",
        "variable.language.super.4d",
        "variable.language.4d"
      ],
      "settings": { "foreground": "#C678DD", "fontStyle": "italic" }
    },
    {
      "scope": "support.table.name.4d",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "storage.type.4d",
      "settings": { "foreground": "#E5C07B" }
    },
    {
      "scope": "constant.language.4d",
      "settings": { "foreground": "#ABB2BF", "fontStyle": "underline" }
    },
    {
      "scope": ["constant.numeric.decimal.4d", "constant.numeric.hexadecimal.4d"],
      "settings": { "foreground": "#D19A66" }
    },
    {
      "scope": ["comment.line.double-slash.4d", "comment.block.4d"],
      "settings": { "foreground": "#5C6370", "fontStyle": "italic" }
    },
    {
      "scope": "string.quoted.double.4d",
      "settings": { "foreground": "#98C379" }
    },
    {
      "scope": "entity.name.function.4d",
      "settings": { "foreground": "#61AFEF" }
    }
  ],
  "semanticTokenColors": {
    "operator:4d":              { "foreground": "#ABB2BF" },
    "keyword:4d":               { "foreground": "#C678DD" },
    "string:4d":                { "foreground": "#98C379" },
    "number:4d":                { "foreground": "#D19A66" },
    "comment:4d":               { "foreground": "#5C6370", "fontStyle": "italic" },
    "type:4d":                  { "foreground": "#E5C07B" },
    "constant:4d":              { "foreground": "#ABB2BF", "fontStyle": "underline" },
    "parameter:4d":             { "foreground": "#E06C75" },
    "variable.local:4d":        { "foreground": "#E06C75" },
    "variable.process:4d":      { "foreground": "#E06C75" },
    "variable.interprocess:4d": { "foreground": "#E06C75" },
    "method:4d":                { "foreground": "#61AFEF" },
    "method.defaultLibrary:4d": { "foreground": "#C678DD", "fontStyle": "italic" },
    "method.plugin:4d":         { "foreground": "#C678DD" },
    "method.static:4d":         { "foreground": "#61AFEF" },
    "function:4d":              { "foreground": "#61AFEF" },
    "property:4d":              { "foreground": "#E06C75" },
    "table:4d":                 { "foreground": "#E5C07B" },
    "field:4d":                 { "foreground": "#E06C75" }
  }
}
