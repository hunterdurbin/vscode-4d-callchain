{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Symphony)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-client",
        "/Users/hunterdurbin/src/4d/symphony"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-client/dist/**/*.js",
        "${workspaceFolder}/packages/core/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Run Extension (no workspace)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-client"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-client/dist/**/*.js",
        "${workspaceFolder}/packages/core/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
