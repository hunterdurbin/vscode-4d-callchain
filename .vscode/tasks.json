{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$tsc",
      "label": "npm: build"
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "packages/vscode-client",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch (client)"
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "packages/core",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch (core)"
    }
  ]
}
